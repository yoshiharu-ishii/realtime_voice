# OpenAI APIキー(必須)。このファイルを .env にコピーして値を設定してください。
OPENAI_API_KEY=sk-...

# 以下は任意(未設定ならデフォルト値を使用)
# REALTIME_MODEL=gpt-realtime
# REALTIME_VOICE=marin
# REALTIME_TRANSCRIBE_MODEL=gpt-4o-transcribe
# SEARCH_MODEL=gpt-5-mini          # web_searchツールの実行に使うモデル
# REALTIME_INSTRUCTIONS=あなたは親切な音声アシスタントです。日本語で簡潔に応答してください。
