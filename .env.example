# OpenAI APIキー(必須)。このファイルを .env にコピーして値を設定してください。
OPENAI_API_KEY=sk-...

# 以下は任意(未設定ならデフォルト値を使用)
# REALTIME_MODEL=gpt-realtime
# REALTIME_VOICE=marin             # ペルソナにvoice指定がない場合のフォールバック
# REALTIME_TRANSCRIBE_MODEL=gpt-4o-transcribe
# SEARCH_MODEL=gpt-5-mini          # web_searchツールの実行に使うモデル
# ※キャラ設定(instructions)は personas/*.md で管理します

# Cognito認証(すべて未設定なら認証なしで動作 = ローカル開発モード)
# COGNITO_REGION=ap-northeast-1
# COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# COGNITO_DOMAIN=https://your-domain.auth.ap-northeast-1.amazoncognito.com
